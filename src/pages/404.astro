---
import BaseLayout from "../layouts/BaseLayout.astro";
import { useTranslations } from "../i18n/utils";
const t = useTranslations("en-us");
---

<BaseLayout title={t("notfound.title")}>
  <section class="py-16 text-center">
    <p class="font-mono text-6xl font-bold text-zinc-900 dark:text-white">404</p>
    <h1 class="mt-4 text-2xl font-bold text-zinc-900 dark:text-white">
      {t("notfound.title")}
    </h1>
    <p class="mt-2 text-zinc-600 dark:text-zinc-400">{t("notfound.text")}</p>
    <a
      href="/"
      class="mt-6 inline-block rounded-full bg-black px-5 py-2.5 font-medium text-white transition-opacity hover:opacity-80 dark:bg-white dark:text-black"
    >
      {t("notfound.home")}
    </a>
  </section>
</BaseLayout>
