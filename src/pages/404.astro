---
import BaseLayout from "../layouts/BaseLayout.astro";
import { useTranslations } from "../i18n/utils";
const t = useTranslations("en");
---

<BaseLayout title={t("notfound.title")}>
  <section class="py-16 text-center">
    <p class="font-mono text-6xl font-bold text-brand-500">404</p>
    <h1 class="mt-4 text-2xl font-bold text-gray-900 dark:text-white">
      {t("notfound.title")}
    </h1>
    <p class="mt-2 text-gray-600 dark:text-gray-400">{t("notfound.text")}</p>
    <a
      href="/"
      class="mt-6 inline-block rounded-lg bg-brand-600 px-5 py-2.5 font-medium text-white transition-colors hover:bg-brand-700"
    >
      {t("notfound.home")}
    </a>
  </section>
</BaseLayout>
