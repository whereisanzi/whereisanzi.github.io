---
import type { Lang } from "../i18n/ui";
import { formatDate, localizedPath } from "../i18n/utils";
import { postSlug, type Article } from "../lib/content";

interface Props {
  post: Article;
  lang: Lang;
}

const { post, lang } = Astro.props;
const href = localizedPath(`/articles/${postSlug(post)}`, lang);
---

<article class="group">
  <a href={href} class="block rounded-xl py-4 transition-colors">
    <div class="flex items-center gap-2 font-mono text-xs text-zinc-500 dark:text-zinc-400">
      <time datetime={post.data.pubDate.toISOString()}>
        {formatDate(post.data.pubDate, lang)}
      </time>
      {
        post.data.tags.length > 0 && (
          <>
            <span>·</span>
            <span>
              {post.data.tags.slice(0, 2).map((tag) => `#${tag}`).join(" ")}
            </span>
          </>
        )
      }
    </div>
    <h3
      class="mt-1 text-lg font-semibold tracking-tight text-zinc-900 decoration-zinc-300 underline-offset-4 group-hover:underline dark:text-white dark:decoration-zinc-600"
    >
      {post.data.title}
    </h3>
    <p class="mt-1 text-sm leading-relaxed text-zinc-600 dark:text-zinc-400">
      {post.data.description}
    </p>
  </a>
</article>
