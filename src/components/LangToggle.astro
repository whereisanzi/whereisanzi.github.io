---
import { getLangFromUrl, stripLangFromPath, useTranslations } from "../i18n/utils";
import { defaultLang } from "../i18n/ui";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const barePath = stripLangFromPath(Astro.url.pathname);
const target = lang === "en" ? "pt" : "en";
const targetPath =
  target === defaultLang
    ? barePath
    : `/${target}${barePath === "/" ? "" : barePath}`;
---

<a
  href={targetPath}
  aria-label={t("lang.switch")}
  title={t("lang.switch")}
  class="grid h-9 min-w-9 place-items-center rounded-lg px-2 font-mono text-xs font-semibold uppercase text-gray-600 transition-colors hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-white/10 dark:hover:text-white"
>
  {target}
</a>
