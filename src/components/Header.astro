---
import { getLangFromUrl, useTranslations, localizedPath } from "../i18n/utils";
import ThemeToggle from "./ThemeToggle.astro";
import LangToggle from "./LangToggle.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const current = Astro.url.pathname.replace(/\/$/, "") || "/";
const links = [
  { href: localizedPath("/", lang), label: t("nav.home") },
  { href: localizedPath("/articles", lang), label: t("nav.articles") },
  { href: localizedPath("/about", lang), label: t("nav.about") },
];

const homeHref = localizedPath("/", lang).replace(/\/$/, "");

function isActive(href: string) {
  const h = href.replace(/\/$/, "") || "/";
  // The home link should only match the exact home path, not every sub-route.
  if (h === homeHref) return current === h;
  return current === h || current.startsWith(h + "/");
}
---

<header
  class="sticky top-0 z-40 border-b border-zinc-100 bg-white/80 backdrop-blur-md dark:border-zinc-800 dark:bg-background-dark/80"
>
  <div class="mx-auto flex h-14 max-w-3xl items-center justify-between px-4 sm:px-6">
    <a
      href={localizedPath("/", lang)}
      class="flex items-center gap-2.5"
      aria-label={t("site.title")}
    >
      <span
        class="grid size-7 place-items-center rounded-full bg-black text-xs font-bold text-white dark:bg-white dark:text-black"
      >
        a
      </span>
      <span class="text-lg font-semibold tracking-tight text-zinc-800 dark:text-zinc-200">
        {t("site.title")}
      </span>
    </a>

    <nav class="flex items-center gap-1">
      {
        links.map((link) => (
          <a
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
            class:list={[
              "rounded-full px-3 py-1.5 text-sm font-medium transition-colors",
              isActive(link.href)
                ? "text-zinc-900 dark:text-white"
                : "text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white",
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <span class="mx-1 h-5 w-px bg-zinc-200 dark:bg-zinc-700"></span>
      <LangToggle />
      <ThemeToggle />
    </nav>
  </div>
</header>
