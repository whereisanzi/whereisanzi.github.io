---
import { getLangFromUrl, useTranslations, localizedPath } from "../i18n/utils";
import ThemeToggle from "./ThemeToggle.astro";
import LangToggle from "./LangToggle.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const current = Astro.url.pathname.replace(/\/$/, "") || "/";
const links = [
  { href: localizedPath("/", lang), label: t("nav.home") },
  { href: localizedPath("/tutorials", lang), label: t("nav.tutorials") },
  { href: localizedPath("/about", lang), label: t("nav.about") },
];

const homeHref = localizedPath("/", lang).replace(/\/$/, "");

function isActive(href: string) {
  const h = href.replace(/\/$/, "") || "/";
  // The home link should only match the exact home path, not every sub-route.
  if (h === homeHref) return current === h;
  return current === h || current.startsWith(h + "/");
}
---

<header
  class="sticky top-0 z-40 border-b border-gray-200/70 bg-white/80 backdrop-blur-md dark:border-white/10 dark:bg-background-dark/80"
>
  <div class="mx-auto flex h-16 max-w-3xl items-center justify-between px-4 sm:px-6">
    <a
      href={localizedPath("/", lang)}
      class="font-mono text-lg font-bold tracking-tight text-gray-900 dark:text-white"
    >
      {t("site.title")}<span class="text-brand-500">.</span>
    </a>

    <nav class="flex items-center gap-1">
      {
        links.map((link) => (
          <a
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
            class:list={[
              "rounded-lg px-3 py-1.5 text-sm font-medium transition-colors",
              isActive(link.href)
                ? "text-brand-600 dark:text-brand-400"
                : "text-gray-600 hover:text-gray-900 dark:text-gray-400 dark:hover:text-white",
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <span class="mx-1 h-5 w-px bg-gray-200 dark:bg-white/10"></span>
      <LangToggle />
      <ThemeToggle />
    </nav>
  </div>
</header>
