---
import type { Lang } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const body: Record<Lang, string[]> = {
  "en-us": [
    "I'm Anderson Anzileiro (anzi), a software engineer who likes building systems from the metal up and training small language models. I've spent over a decade shipping software, including time at Nubank and as a Staff Engineer at Stone, and founding a startup along the way.",
    "These days most of my energy goes into Maracatu, an open-source initiative from Brazil working on foundation models, civic AI and network infrastructure. I train open-weight Brazilian Portuguese LLMs from scratch, write low-level systems in Rust, and build tools that put public data within everyone's reach.",
    "This blog is where I keep articles, notes and write-ups about that work, mostly so future me can find them again, and maybe they help you too. Everything here is open source.",
  ],
  "pt-br": [
    "Eu sou o Anderson Anzileiro (anzi), engenheiro de software que gosta de construir sistemas desde o metal e treinar modelos de linguagem pequenos. Passei mais de uma década entregando software, incluindo uma temporada no Nubank e como Staff Engineer na Stone, e fundei uma startup pelo caminho.",
    "Hoje a maior parte da minha energia vai para a Maracatu, uma iniciativa open source brasileira focada em foundation models, IA cívica e infraestrutura de rede. Treino LLMs de português do Brasil com pesos abertos, do zero, escrevo sistemas de baixo nível em Rust e construo ferramentas que colocam dados públicos ao alcance de todo mundo.",
    "Este blog é onde guardo artigos, anotações e write-ups sobre esse trabalho, principalmente para o meu eu do futuro reencontrar, e quem sabe ajudar você também. Tudo aqui é código aberto.",
  ],
};

const projectsHeading = {
  "en-us": "What I'm building",
  "pt-br": "No que estou trabalhando",
};

const projects = [
  {
    name: "Maracatu",
    href: "https://maracatu.org",
    desc: {
      "en-us": "Open-weight Brazilian Portuguese LLMs, trained from scratch.",
      "pt-br": "LLMs de português do Brasil com pesos abertos, treinados do zero.",
    },
  },
  {
    name: "Calunga",
    href: "https://github.com/maracatu-org/calunga",
    desc: {
      "en-us": "Civic AI: chat and RAG over Brazilian public spending data.",
      "pt-br": "IA cívica: chat e RAG sobre os gastos públicos brasileiros.",
    },
  },
  {
    name: "catraca",
    href: "https://github.com/maracatu-org/catraca",
    desc: {
      "en-us":
        "Single-host TCP dispatcher in Rust: io_uring AcceptMulti and SCM_RIGHTS fd handoff.",
      "pt-br":
        "Dispatcher TCP em Rust: io_uring AcceptMulti e handoff de fd via SCM_RIGHTS.",
    },
  },
  {
    name: "TAG",
    href: "https://github.com/whereisanzi/tag",
    desc: {
      "en-us":
        "A domain-centric, functional software architecture for consistent services.",
      "pt-br":
        "Uma arquitetura de software funcional e centrada em domínio para serviços consistentes.",
    },
  },
];

const links = [
  { label: "GitHub", href: "https://github.com/whereisanzi" },
  { label: "Maracatu", href: "https://maracatu.org" },
  { label: "Hugging Face", href: "https://huggingface.co/maracatu-labs" },
  { label: "RSS", href: "/rss.xml" },
];
---

<section class="prose max-w-none text-zinc-700 dark:text-zinc-300">
  <h1 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-white">
    {t("about.title")}
  </h1>
  {body[lang].map((p) => <p>{p}</p>)}

  <h2 class="not-prose mt-10 text-sm font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400">
    {projectsHeading[lang]}
  </h2>
  <ul class="not-prose mt-4 space-y-4">
    {
      projects.map((project) => (
        <li>
          <a
            href={project.href}
            class="font-mono text-base font-semibold text-zinc-900 decoration-zinc-300 underline-offset-4 hover:underline dark:text-white dark:decoration-zinc-600"
          >
            {project.name}
          </a>
          <p class="mt-0.5 text-sm text-zinc-600 dark:text-zinc-400">
            {project.desc[lang]}
          </p>
        </li>
      ))
    }
  </ul>

  <div class="not-prose mt-10 flex flex-wrap gap-3">
    {
      links.map((link) => (
        <a
          href={link.href}
          class="rounded-full border border-zinc-200 px-4 py-2 font-mono text-sm text-zinc-700 transition-colors hover:border-zinc-900 hover:text-zinc-900 dark:border-zinc-700 dark:text-zinc-300 dark:hover:border-white dark:hover:text-white"
        >
          {link.label}
        </a>
      ))
    }
  </div>
</section>
