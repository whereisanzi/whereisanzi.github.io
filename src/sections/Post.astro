---
import type { Lang } from "../i18n/ui";
import { useTranslations, formatDate, localizedPath } from "../i18n/utils";
import { readingTime, type Article } from "../lib/content";

interface Props {
  post: Article;
  lang: Lang;
}
const { post, lang } = Astro.props;
const t = useTranslations(lang);
const minutes = readingTime(post.body);
---

<article>
  <a
    href={localizedPath("/articles", lang)}
    class="font-mono text-sm text-zinc-900 hover:underline dark:text-white"
  >
    ← {t("post.back")}
  </a>

  <header class="mt-6">
    <div class="flex flex-wrap items-center gap-2 font-mono text-xs text-zinc-500 dark:text-zinc-400">
      <time datetime={post.data.pubDate.toISOString()}>
        {formatDate(post.data.pubDate, lang)}
      </time>
      <span>·</span>
      <span>{minutes} {t("post.minRead")}</span>
      {
        post.data.tags.length > 0 && (
          <>
            <span>·</span>
            <span class="text-zinc-900 dark:text-white">
              {post.data.tags.map((tag) => `#${tag}`).join(" ")}
            </span>
          </>
        )
      }
    </div>
    <h1
      class="mt-3 text-3xl font-bold leading-tight tracking-tight text-zinc-900 dark:text-white sm:text-4xl"
    >
      {post.data.title}
    </h1>
    <p class="mt-3 text-lg text-zinc-600 dark:text-zinc-400">
      {post.data.description}
    </p>
  </header>

  <div class="prose mt-10 max-w-none text-zinc-700 dark:text-zinc-300">
    <slot />
  </div>
</article>
